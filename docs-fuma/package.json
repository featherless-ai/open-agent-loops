{
  "name": "docs-fuma",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun run sidebar && bun run snippets",
    "dev": "node scripts/gen-snippets.mjs --watch & next dev",
    "prebuild": "bun run sidebar && bun run snippets",
    "build": "next build",
    "start": "next start",
    "sidebar": "node scripts/gen-api-meta.mjs",
    "snippets": "node scripts/gen-snippets.mjs",
    "postinstall": "fumadocs-mdx"
  },
  "comment": "entities pinned to v6 so parse5 (needs `entities/escape`) resolves under bun's hoisting; only parse5 (v6 subpaths) and markdown-it (bare, v6-compatible) use it.",
  "overrides": {
    "entities": "^6"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "animejs": "^4.5.0",
    "fumadocs-core": "^16.9.3",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.9.3",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3"
  }
}
