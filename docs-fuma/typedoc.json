{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["../agent-loop-core/index.ts"],
  "tsconfig": "../tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "content/docs/api",
  "excludeInternal": true,
  "readme": "none",
  "entryFileName": "index",
  "hidePageTitle": true,
  "hideBreadcrumbs": true,
  "useCodeBlocks": true,
  "expandObjects": true,
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "indexFormat": "table",
  "groupOrder": [
    "Core",
    "Hooks & Gating",
    "Messages & Events",
    "Model",
    "Defining Tools",
    "Tool Registry",
    "Built-in Tools",
    "Stop Conditions",
    "Memory",
    "Permissions",
    "Credentials",
    "Composition",
    "Workflow",
    "Testing",
    "*"
  ]
}
