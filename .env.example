# Template for .env — copy to `.env` and fill in. The real `.env` is gitignored.
#
#   cp .env.example .env
#
# These configure OpenAICompatibleModel (agent-loop-core/providers/openai-compatible.ts),
# which points the `openai` SDK at any OpenAI-compatible endpoint
# (Featherless, vLLM, Together, Groq, Fireworks, DeepSeek, ...).

# API key for the endpoint.
LLM_API_KEY=

# Base URL of the OpenAI-compatible endpoint, e.g. https://api.featherless.ai/v1
LLM_BASE_URL=https://api.featherless.ai/v1

# Model id to call, e.g. deepseek-ai/DeepSeek-V3.1
LLM_MODEL=
