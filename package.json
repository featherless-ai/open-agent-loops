  },
  "dependencies": {
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5"
  }
}
