{
  "name": "agent-core",
  "version": "0.0.1",
  "description": "A minimal, provider-agnostic agentic loop. Plug-and-play seams behind interfaces.",
  "type": "module",
  "module": "agent-core/index.ts",
  "types": "agent-core/index.ts",
  "exports": {
    ".": "./agent-core/index.ts"
  },
