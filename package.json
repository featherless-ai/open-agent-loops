{
  "name": "@open-agent-loops/core",
  "version": "0.0.1",
  "description": "A minimal, provider-agnostic agentic loop. Plug-and-play seams behind interfaces.",
  "license": "MIT",
  "author": "Michael Chung <michael.chung@databites.ca>",
  "homepage": "https://github.com/ArEnSc/advance-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArEnSc/advance-agent.git"
  },
  "bugs": {
    "url": "https://github.com/ArEnSc/advance-agent/issues"
  },
  "keywords": [
    "agent",
    "agentic",
    "llm",
    "openai",
    "tool-calling",
    "ai"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./mocks/mock-model": {
      "types": "./dist/mocks/mock-model.d.ts",
      "import": "./dist/mocks/mock-model.js",
      "default": "./dist/mocks/mock-model.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.js",
      "default": "./dist/providers/openai.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "demo": "bun run examples/running-product.ts",
    "test": "bun test agent-core",
    "test:system": "bun test system-tests",
    "number-test": "bun run system-tests/reasoning-number-test.ts",
    "typecheck": "tsc --noEmit",
    "docs:site": "cd docs-fuma && bun run dev",
    "docs:site:build": "cd docs-fuma && bun run build"
  },
  "dependencies": {
    "zod": "^4"
  },
  "peerDependencies": {
    "openai": "^6"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "openai": "6.44.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
