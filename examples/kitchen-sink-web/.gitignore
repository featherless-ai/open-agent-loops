# Next.js build output + caches
/.next/
/out/
/build
.turbo/

# Next-generated types (regenerated on dev/build)
next-env.d.ts

# TypeScript incremental build info
*.tsbuildinfo

# Dependencies (also covered by the repo-root .gitignore)
/node_modules

# npm lockfile — this example runs on Deno; deno.lock is the lockfile
/package-lock.json

# Local env + logs
.env*.local
*.log
.DS_Store
