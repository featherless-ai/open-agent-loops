# Next.js build output + caches
/.next/
/out/
/build
.turbo/

# Next-generated types (regenerated on dev/build)
next-env.d.ts

# TypeScript incremental build info
*.tsbuildinfo

# Dependencies (also covered by the repo-root .gitignore)
/node_modules

# Local env + logs
.env*.local
*.log
.DS_Store

# deno desktop generated entry file (random suffix, regenerated each run)
.deno_desktop_entry-*.ts
