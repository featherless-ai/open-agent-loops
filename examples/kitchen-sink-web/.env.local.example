# Copy to .env.local. The kitchen-sink agent talks to Featherless by default.
LLM_API_KEY=rc_your_featherless_key_here
LLM_BASE_URL=https://api.featherless.ai/v1
# Tool-calling-clean. Avoid GLM-* here — it emits broken empty-key tool-call args.
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# No key? Leave LLM_API_KEY unset, OR uncomment the next line, to run the scripted
# mock model (no network, canned "kitchen-sink-ok" reply).
# MOCK=1
