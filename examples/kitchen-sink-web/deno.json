{
  "//": "Deno Desktop host config for the kitchen-sink. `deno desktop .` auto-detects the Next.js app and wraps it in a native webview; `deno desktop --hmr .` runs the dev server. Requires Deno 2.9+ (the `desktop` subcommand).",
  "unstable": [
    "bare-node-builtins",
    "detect-cjs",
    "node-globals",
    "unsafe-proto",
    "sloppy-imports"
  ],
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "desktop": "deno desktop --hmr ."
  },
  "imports": {
    "@open-agent-loops/core": "../../dist/index.js",
    "@open-agent-loops/core/mocks/mock-model": "../../dist/mocks/mock-model.js",
    "@open-agent-loops/core/providers/openai": "../../dist/providers/openai.js"
  },
  "desktop": {
    "app": {
      "name": "Kitchen Sink",
      "identifier": "com.openagentloops.kitchensink"
    }
  }
}
