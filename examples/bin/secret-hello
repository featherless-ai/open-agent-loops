#!/usr/bin/env bash
#
# secret-hello — a toy CLI for the skills docs. It greets you, but ONLY if you
# present the right credential. The secret is read from the SECRET_HELLO_TOKEN
# environment variable (exactly how `gh` reads GH_TOKEN), so an agent can pass it
# inline:
#
#     SECRET_HELLO_TOKEN={{secret_hello_token}} secret-hello Ada
#
# The {{secret_hello_token}} placeholder is swapped for the real value by
# `withCredentials` at execution time. With the wrong or absent token this
# refuses and exits non-zero — proof the credential is doing real work, not
# decoration.
set -euo pipefail

# In real life this check happens server-side; hard-coded here so the example is
# self-contained and offline.
readonly EXPECTED_TOKEN="s3cr3t-hello-key"

if [[ "${SECRET_HELLO_TOKEN:-}" != "$EXPECTED_TOKEN" ]]; then
  echo "secret-hello: unauthorized — set SECRET_HELLO_TOKEN to the access key" >&2
  exit 1
fi

name="${1:-world}"
echo "Hello, ${name}! (credential accepted)"
